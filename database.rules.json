{
  "rules": {
    ".read":  "auth != null",
    ".write": "auth != null",

    "tac_locs": {
      "$uid": {
        ".validate": "newData.hasChildren(['lat','lng','ts']) && newData.child('lat').isNumber() && newData.child('lng').isNumber()"
      }
    },

    "tac_sos": {
      "$uid": {
        ".validate": "newData.hasChildren(['ts']) && newData.child('ts').isNumber()"
      }
    },

    "tac_photos": {
      "$personId": {
        ".validate": "newData.isString() && newData.val().length < 500000"
      }
    },

    "tac_fcm_tokens": {
      "$personId": {
        ".validate": "newData.isString() || (newData.hasChild('token') && newData.child('token').isString())"
      }
    },

    "tac_chat": {
      "$msgId": {
        ".validate": "newData.hasChildren(['ts','text']) && newData.child('text').isString() && newData.child('text').val().length < 4000"
      }
    }
  }
}
