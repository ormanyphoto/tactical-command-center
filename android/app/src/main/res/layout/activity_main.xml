<?xml version="1.0" encoding="utf-8"?>
<!--
  fitsSystemWindows="true" tells Android to automatically apply the system
  window insets (status bar + nav bar + camera cutout) as PADDING on this
  FrameLayout. The WebView child (match_parent) then fills only the safe
  area between the status bar and the nav bar. This is the old but still
  reliable way to get "content below camera, above nav bar" on Android 14+.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#07090a">

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#07090a" />

</FrameLayout>
